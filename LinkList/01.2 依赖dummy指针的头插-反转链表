#include"iostream"
#include"LinkList.h"
#include<forward_list>
using namespace std;
void Reverse(LinkList& list) 
{
	Node* p = list.m_head->next;
	list.m_head->next = NULL;
	if (p == NULL) return;
	while (p != NULL) 
	{
		Node* q = p->next;
		p->next = list.m_head->next;
		list.m_head->next = p;
		p = q;
	}
}
void test01() 
{
	LinkList list;
	list.push_back(1);
	list.push_back(2);
	list.push_back(3);
	list.push_back(4);
	list.push_back(5);
	list.print();
	//利用头插法逆序元素
	Reverse(list);
	list.print();
}
int main() 
{
	test01();
	return 0;
}
